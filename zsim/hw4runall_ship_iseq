#!/bin/sh

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
cd "$script_dir" || exit 1

repl="SHiP-ISeq"
zsim_bin="./build/opt/zsim"
config_dir="configs/hw4/$repl"

spec_benches="bzip2 gcc mcf hmmer sjeng libquantum milc cactusADM leslie3d namd soplex calculix lbm xalan"
parsec_benches="blackscholes bodytrack canneal dedup fluidanimate freqmine streamcluster swaptions x264"

suite="ALL"
bg_mode=1
ok_count=0
fail_count=0

usage() {
    echo ""
    echo "Usage: ./hw4runall_ship_iseq [ALL|SPEC|PARSEC] [--fg]"
    exit 1
}

if [ "$#" -gt 2 ]; then
    usage
fi

for arg in "$@"; do
    case "$arg" in
        ALL|SPEC|PARSEC)
            suite=$arg
            ;;
        --fg)
            bg_mode=0
            ;;
        *)
            usage
            ;;
    esac
done

if [ ! -d "$config_dir" ]; then
    echo "Missing $config_dir. Run this script from the zsim directory."
    exit 1
fi

if [ ! -x "$zsim_bin" ]; then
    echo "Missing executable $zsim_bin. Build zsim first, then rerun this script."
    exit 1
fi

driver_dir="outputs/hw4/$repl/_driver"
mkdir -p "$driver_dir"
driver_log="$driver_dir/${suite}.log"
pid_file="$driver_dir/${suite}.pid"
fail_log="$driver_dir/${suite}.failures"
cfg_list="$driver_dir/${suite}.configs"

run_cfg() {
    cfg="$1"
    bench=$(basename "$cfg" .cfg)
    log_name=${bench%_8c_simlarge}
    outdir="outputs/hw4/$repl/$bench"
    logfile="$outdir/$log_name.log"

    mkdir -p "$outdir"
    echo "[$(date)] START $cfg"
    echo "$zsim_bin $cfg > $logfile 2>&1"
    "$zsim_bin" "$cfg" > "$logfile" 2>&1
    status=$?
    if [ "$status" -eq 0 ]; then
        ok_count=$((ok_count + 1))
        echo "[$(date)] DONE  $cfg"
    else
        fail_count=$((fail_count + 1))
        echo "[$(date)] FAIL  $cfg exit=$status"
        echo "$cfg exit=$status log=$logfile" >> "$fail_log"
    fi
}

run_spec() {
    for bench in $spec_benches; do
        run_cfg "$config_dir/${bench}.cfg"
    done
}

run_parsec() {
    for bench in $parsec_benches; do
        run_cfg "$config_dir/${bench}_8c_simlarge.cfg"
    done
}

run_selected() {
    case "$suite" in
        SPEC)   run_spec ;;
        PARSEC) run_parsec ;;
        ALL)
            find "$config_dir" -maxdepth 1 -type f -name '*.cfg' | sort > "$cfg_list"
            while IFS= read -r cfg; do
                run_cfg "$cfg"
            done < "$cfg_list"
            ;;
        *)
            echo "Invalid suite: $suite"
            usage
            ;;
    esac
}

if [ "$bg_mode" -eq 1 ]; then
    nohup "$0" "$suite" --fg > "$driver_log" 2>&1 &
    bg_pid=$!
    echo "$bg_pid" > "$pid_file"
    echo "Started in background."
    echo "PID: $bg_pid"
    echo "Driver log: $driver_log"
    echo "PID file: $pid_file"
    exit 0
fi

rm -f "$fail_log"
rm -f "$cfg_list"
run_selected
echo "[$(date)] SUMMARY ok=$ok_count failed=$fail_count"
if [ "$fail_count" -ne 0 ]; then
    echo "Failures: $fail_log"
    exit 1
fi
