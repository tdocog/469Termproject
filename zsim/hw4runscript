#!/bin/sh

if [ "$#" -ne 3 ]; then
    echo ""
    echo "Usage: ./hw4runscript <suite> <benchmark> <repl_policy>"
    echo "    (suite) benchmarks: "
    echo "      -- (SPEC) bzip2 gcc mcf hmmer xalancbmk milc cactusADM leslie3d namd calculix sjeng libquantum soplex lbm"
    echo "      -- (PARSEC) blackscholes bodytrack fluidanimate streamcluster swaptions canneal x264"
    echo "    repl_policy: LRU SHiP-ISeq"
else
    suite=$1
    bench=$2
    repl=$3
    run_label="500M"
    output_root="outputs/hw4/$run_label/$repl"

    if [ "$bench" = "xalancbmk" ]; then
        bench="xalan"
    fi

    # your simulation results will be saved to outputs/hw4/500M/$repl/$bench/
    if [ "$suite" = "SPEC" ]; then
        valid_benches=" bzip2 gcc mcf hmmer xalan milc cactusADM leslie3d namd calculix sjeng libquantum soplex lbm "
        case "$valid_benches" in
            *" $bench "*) ;;
            *) echo "Unsupported SPEC benchmark for this 500M set: $bench"; exit 1 ;;
        esac

        mkdir -p "$output_root/${bench}"
        echo "./build/opt/zsim configs/hw4/$repl/${bench}.cfg > $output_root/${bench}/${bench}.log 2>&1 &"
        ./build/opt/zsim configs/hw4/$repl/${bench}.cfg > "$output_root/${bench}/${bench}.log" 2>&1 &
    elif [ "$suite" = "PARSEC" ]; then
        valid_benches=" blackscholes bodytrack fluidanimate streamcluster swaptions canneal x264 "
        case "$valid_benches" in
            *" $bench "*) ;;
            *) echo "Unsupported PARSEC benchmark for this 500M set: $bench"; exit 1 ;;
        esac

        mkdir -p "$output_root/${bench}_8c_simlarge"
        echo "./build/opt/zsim configs/hw4/$repl/${bench}_8c_simlarge.cfg > $output_root/${bench}_8c_simlarge/${bench}.log 2>&1 &"
        ./build/opt/zsim configs/hw4/$repl/${bench}_8c_simlarge.cfg > "$output_root/${bench}_8c_simlarge/${bench}.log" 2>&1 &
    else
        echo "No such benchmark suite, please specify SPEC or PARSEC"
    fi
fi
